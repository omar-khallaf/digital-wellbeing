pkgname=digital-wellbeing
pkgbase=digital-wellbeing
pkgver=0.1.0
pkgrel=1
pkgdesc="Digital Wellbeing for Wayland — system daemon, GUI, Hyprland plugin"
arch=('x86_64' 'aarch64')
url="https://github.com/omar/digital-wellbeing"
license=('MIT')
depends=(
  'dbus'
  'glibc'
  'gcc-libs'
)
makedepends=(
  'cargo'
  'cmake'
  'ninja'
  'gcc'
  'pkg-config'
  'wayland-protocols'
  'glslang'
  'lua'
)
optdepends=(
  'hyprland: compositor plugin backend'
)
source=("$pkgname::git+https://github.com/omar/digital-wellbeing.git#tag=v$pkgver")
sha256sums=('SKIP')
options=('!lto')

# Build both Rust binaries and the plugin in one shot.
build() {
  cd "$srcdir/$pkgname"

  # Rust workspace (daemon + gui + core)
  cargo build --release -p wellbeing-daemon -p wellbeing-gui --workspace

  # Hyprland compositor plugin
  cd plugins/hyprland/app
  cmake -B build -G Ninja \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build
}

package_digital-wellbeing-common() {
  pkgdesc="Digital Wellbeing common files (D-Bus policy, systemd units)"
  depends=('dbus')

  cd "$srcdir/$pkgname"

  install -Dm644 deploy/dbus/org.wellbeing.v1.Controller.conf \
    "$pkgdir/usr/share/dbus-1/system.d/org.wellbeing.v1.Controller.conf"
  install -Dm644 deploy/dbus/org.wellbeing.v1.Manager.conf \
    "$pkgdir/usr/share/dbus-1/system.d/org.wellbeing.v1.Manager.conf"
  install -Dm644 deploy/systemd/digital-wellbeing-daemon.service \
    "$pkgdir/usr/lib/systemd/system/digital-wellbeing-daemon.service"
  install -Dm644 deploy/system-services/org.wellbeing.v1.Controller.service \
    "$pkgdir/usr/share/dbus-1/system-services/org.wellbeing.v1.Controller.service"
}

package_wellbeing-daemon() {
  pkgdesc="Digital Wellbeing system daemon (root)"
  depends=(
    'digital-wellbeing-common'
    'dbus'
    'glibc'
  )
  provides=("$pkgbase")
  conflicts=("$pkgbase")

  cd "$srcdir/$pkgname"
  install -Dm755 target/release/wellbeing-daemon \
    "$pkgdir/usr/bin/wellbeing-daemon"
}

package_wellbeing-gui() {
  pkgdesc="Digital Wellbeing desktop GUI"
  depends=(
    'digital-wellbeing-common'
    'dbus'
    'wayland'
    'libxkbcommon'
    'fontconfig'
    'freetype2'
    'cairo'
    'pango'
    'libinput'
    'glibc'
  )
  optdepends=(
    'hyprland: for Wayland sessions'
  )

  cd "$srcdir/$pkgname"
  install -Dm755 target/release/wellbeing-gui \
    "$pkgdir/usr/bin/wellbeing-gui"
}

package_wellbeing-hyprland-plugin() {
  pkgdesc="Hyprland compositor plugin for Digital Wellbeing"
  depends=(
    'digital-wellbeing-common'
    'dbus'
    'hyprland>=0.41'
    'wayland'
    'mesa'
    'libxkbcommon'
    'glslang'
    'lua'
    'glibc'
  )
  provides=("$pkgbase-plugin")
  conflicts=("$pkgbase-plugin")

  cd "$srcdir/$pkgname/plugins/hyprland/app/build"
  install -Dm755 wellbeing_manager.so \
    "$pkgdir/usr/lib/hyprland-plugins/wellbeing_manager.so"
}
